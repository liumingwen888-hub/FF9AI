---
import { getCollection } from 'astro:content';
import PageShell from '../../components/layout/PageShell.astro';
import ContentCard from '../../components/layout/ContentCard.astro';
import { entrySlug } from '../../lib/content';

const posts = (await getCollection('blog'))
  .filter((post) => !post.data.draft)
  .sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf());
---

<PageShell
  title="FF9 AI 博客 | AI 自动化与线上游戏运营"
  description="阅读 FF9 AI 关于私有化 AI 自动化、线上游戏后台流程、风险复核和结算对账的实践文章。"
  canonical="/blog/"
>
  <section class="section-padding pb-24">
    <div class="mb-14 max-w-4xl">
      <div class="text-label mb-4">[ Blog ]</div>
      <h1 class="text-[clamp(40px,7vw,96px)] leading-[0.95] tracking-[-0.06em]">AI 自动化运营笔记</h1>
      <p class="mt-6 max-w-2xl text-lg leading-8 text-[#666]">围绕私有化部署、风险复核、结算对账和运营信号整理，持续沉淀可落地的流程自动化经验。</p>
    </div>
    <div class="grid gap-4 md:grid-cols-2">
      {posts.map((post) => (
        <ContentCard
          href={`/blog/${entrySlug(post.id)}/`}
          title={post.data.title}
          description={post.data.description}
          meta={`${post.data.category} / ${post.data.date.toISOString().slice(0, 10)}`}
        />
      ))}
    </div>
  </section>
</PageShell>

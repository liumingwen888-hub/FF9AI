---
import PageShell from './PageShell.astro';

interface Solution {
  slug: string;
  eyebrow: string;
  title: string;
  description: string;
  pains: string[];
  outputs: string[];
}

interface Props {
  solution: Solution;
}

const { solution } = Astro.props;
---

<PageShell
  title={`${solution.title} | FF9 AI 解决方案`}
  description={solution.description}
  canonical={`/solutions/${solution.slug}/`}
>
  <section class="section-padding pb-24">
    <div class="mb-16 max-w-5xl">
      <div class="text-label mb-4">[ {solution.eyebrow} ]</div>
      <h1 class="text-[clamp(42px,7vw,104px)] leading-[0.92] tracking-[-0.07em]">{solution.title}</h1>
      <p class="mt-8 max-w-2xl text-lg leading-8 text-[#666]">{solution.description}</p>
      <a href="/contact/" class="btn-primary mt-8">发一个流程让我们评估</a>
    </div>

    <div class="grid gap-px bg-[#e5e5e5] md:grid-cols-2">
      <div class="bg-white p-8">
        <div class="text-label mb-5">Pain Points</div>
        <h2 class="mb-6 text-3xl">人工流程的问题</h2>
        <ul class="space-y-4 text-[#555]">
          {solution.pains.map((item) => <li class="border-t border-[#e5e5e5] pt-4">{item}</li>)}
        </ul>
      </div>
      <div class="bg-black p-8 text-white">
        <div class="text-label mb-5" style="color: rgba(255,255,255,.55)">Outputs</div>
        <h2 class="mb-6 text-3xl">AI 输出什么</h2>
        <ul class="space-y-4 text-white/70">
          {solution.outputs.map((item) => <li class="border-t border-white/15 pt-4">{item}</li>)}
        </ul>
      </div>
    </div>

    <div class="mt-16 grid gap-8 md:grid-cols-3">
      <div>
        <div class="text-label mb-3">01</div>
        <h2 class="mb-3 text-2xl">先用脱敏样本</h2>
        <p class="text-sm leading-7 text-[#666]">第一次评估不需要真实用户数据，用脱敏样本和字段说明判断流程是否适合自动化。</p>
      </div>
      <div>
        <div class="text-label mb-3">02</div>
        <h2 class="mb-3 text-2xl">AI 负责整理判断</h2>
        <p class="text-sm leading-7 text-[#666]">AI 先完成识别、归类、摘要和证据链整理，减少人工重复筛选。</p>
      </div>
      <div>
        <div class="text-label mb-3">03</div>
        <h2 class="mb-3 text-2xl">人负责关键复核</h2>
        <p class="text-sm leading-7 text-[#666]">关键结果仍由负责人确认，避免黑箱决策，保留可追溯记录。</p>
      </div>
    </div>
  </section>
</PageShell>

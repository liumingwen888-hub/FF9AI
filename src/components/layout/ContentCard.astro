---
interface Props {
  title: string;
  description: string;
  href: string;
  meta?: string;
}

const { title, description, href, meta } = Astro.props;
---

<a href={href} class="group block border border-[#e5e5e5] bg-white p-6 transition-colors hover:bg-[#f7f7f7]">
  {meta && <div class="mono mb-4 text-xs uppercase tracking-[0.08em] text-[#777]">{meta}</div>}
  <h2 class="mb-3 text-2xl leading-tight">{title}</h2>
  <p class="text-sm leading-7 text-[#666]">{description}</p>
  <div class="mt-6 text-sm font-medium">
    阅读更多 <span class="inline-block transition-transform group-hover:translate-x-1">→</span>
  </div>
</a>
